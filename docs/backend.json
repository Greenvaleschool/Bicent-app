{
  "entities": {
    "Trade": {
      "title": "Trade",
      "description": "A record of a market execution order.",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "sell"] },
        "price": { "type": "number" },
        "amount": { "type": "number" },
        "total": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["completed", "pending", "cancelled"] },
        "isPaper": { "type": "boolean" }
      },
      "required": ["symbol", "type", "price", "amount", "total", "timestamp", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User specific identity, settings, and terminal balance.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "balance": { "type": "number" },
        "preferredTheme": { "type": "string", "enum": ["light", "dark"] },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "region": { "type": "string" },
        "language": { "type": "string" },
        "isNotificationsEnabled": { "type": "boolean" },
        "is2FAEnabled": { "type": "boolean" },
        "masterPin": { "type": "string", "description": "4-digit secure access code." },
        "mfaEmail": { "type": "string", "format": "email" },
        "registeredAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a conversation.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "imageUrl": { "type": "string", "description": "Optional data URI or URL for images generated by AI." },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "Task": {
      "title": "Task",
      "description": "A productivity item managed by PAL.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "dueAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Collection of all market trades."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/users/{userId}/chats/{messageId}": {
      "schema": "ChatMessage",
      "description": "Persistent conversation history for mypal ai."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Productivity tasks managed by PAL."
    }
  }
}